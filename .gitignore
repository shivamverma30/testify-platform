# =========================================================
# Root-level repository security .gitignore
# =========================================================

# Secrets and environment files
.env
.env.*
*.env
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
*.kdbx
*.asc
*.gpg
*.pgp
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.secret
*.secrets
secrets/
secret/

# Documentation files and docs directories
docs/
*.md
*.mdx
*.rst
*.adoc
*.txt
*.pdf
*.doc
*.docx
*.rtf
*.odt
*.ppt
*.pptx
*.xls
*.xlsx
*.csv
*.html

# Node.js / package manager dependencies
node_modules/
backend/node_modules/
frontend/node_modules/
.pnp.*
.yarn/
.npm/

# Logs and runtime output
logs/
log/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.pid
*.pid.lock
*.seed

# Build and generated artifacts
dist/
build/
out/
coverage/
.nyc_output/
*.tsbuildinfo
*.lcov

# Next.js artifacts
.next/
.next/cache/

# Prisma and database artifacts
prisma/generated/
backend/prisma/generated/
*.db
*.sqlite
*.sqlite3

# Uploads and user-generated storage
uploads/
backend/uploads/
frontend/uploads/

# Cache and temp files
.cache/
cache/
tmp/
temp/
.temp/
.parcel-cache/
.eslintcache
.stylelintcache

# Test and report artifacts
test-results/
playwright-report/
allure-results/
allure-report/
junit.xml
report.*.json

# IDE and editor files
.vscode/
.vscode-test/
.idea/
*.iml

# OS/system files
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Misc local files
*.tmp
*.bak
*.swp
*.swo
*.orig